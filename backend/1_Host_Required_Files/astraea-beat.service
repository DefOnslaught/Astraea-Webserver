[Unit]
Description=Astraea Celery Beat (Scheduler)
After=network.target redis.service

[Service]
User=darren
Group=www-data
WorkingDirectory=/opt/Astraea-Webserver/backend
RuntimeDirectory=celery
ExecStart=/opt/Astraea-Webserver/backend/venv/bin/celery -A backend beat \
    --pidfile=/run/celery/beat.pid \
    --logfile=/opt/Astraea-Webserver/backend/logs/celery-beat.log --loglevel=INFO
Restart=always

[Install]
WantedBy=multi-user.target